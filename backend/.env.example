# 后端会自动读取以下位置的配置：
# 1. 项目根目录 .env
# 2. 项目根目录 .env.local
# 3. backend/.env
# 4. backend/.env.local

BACKEND_HOST=0.0.0.0
BACKEND_PORT=52000
FLASK_DEBUG=false
CORS_ALLOW_ORIGIN=*

WEATHER_API_BASE_URL=http://weather-api.jsjldzkj.com/api
WEATHER_APP_ID=dashboard
WEATHER_SECRET_KEY=
WEATHER_TIMEOUT_SECONDS=30

# 当前版本不再使用本地模拟数据。保持 false。
WEATHER_ALLOW_MOCK=false
WEATHER_FORCE_MOCK=false

# 上游签名模式。优先使用 json；如果真实接口校验失败，再尝试 concat。
# json   => HMAC(secret, {"appid":"...","timestamp":"..."})
# concat => HMAC(secret, appid + timestamp)
WEATHER_HMAC_MODE=json
